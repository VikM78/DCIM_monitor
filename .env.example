# ==================== БАЗА ДАННЫХ ====================
DB_MESSAGE_NAME=message_db
DB_MESSAGE_USER=DCIM_Archive
DB_MESSAGE_PASSWORD=your_password_here
DB_MESSAGE_HOST=localhost
DB_MESSAGE_PORT=5432
DB_MESSAGE_MAX_RETRIES=3
DB_MESSAGE_RETRY_DELAY=1

# ==================== НАСТРОЙКИ МОНИТОРИНГА ====================
MONITOR_INTERVAL=60
MAX_FAILURES=5
ENABLE_ALERTS=true
ADMIN_EMAIL=admin@example.com
NEW_SUBS_THRESHOLD=100
ACTIVE_LOW_THRESHOLD=10
SCHEDULE_CHECK_INTERVAL=60

# ==================== SMTP ДЛЯ УВЕДОМЛЕНИЙ ====================
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_USER=your-email@mail.ru
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@mail.ru

# ==================== НАСТРОЙКИ FLASK ====================
SECRET_KEY=your-super-secret-key-here
FLASK_DEBUG=False
FLASK_ENV=production
SESSION_COOKIE_SECURE=True
SESSION_LIFETIME=3600

# ==================== ПРОЧЕЕ ====================
LOG_LEVEL=INFO
PYTHON_VERSION=3.9